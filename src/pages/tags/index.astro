---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Collect all tags and their counts
const tagMap = new Map<string, number>();
posts.forEach(post => {
  (post.data.tags || []).forEach(tag => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签 — resigned's blog" description="所有文章标签">
  <Header />

  <main class="flex-1 w-full max-w-3xl mx-auto px-4 py-12 sm:px-6">
    <h1 class="font-mono text-3xl font-bold mb-2 flex items-center gap-2">
      <span class="text-accent">#</span> 标签
    </h1>
    <p class="text-[var(--text-muted)] mb-8">共 {tags.length} 个标签，{posts.length} 篇文章</p>

    <div class="flex flex-wrap gap-2">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class="group flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-[var(--border)] text-sm font-mono hover:border-accent hover:text-accent transition-all"
        >
          #{tag}
          <span class="text-xs text-[var(--text-muted)] group-hover:text-accent/70">{count}</span>
        </a>
      ))}
    </div>

    {tags.length === 0 && (
      <p class="text-[var(--text-muted)] font-mono text-sm mt-4">
        // 还没有标签
      </p>
    )}
  </main>

  <Footer />
</BaseLayout>
