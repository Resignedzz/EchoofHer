---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const snippets = (await getCollection('snippets'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(snippets.flatMap(s => s.data.tags))];
---

<BaseLayout title="代码片段 - resigned's blog" description="日常积累的代码片段和笔记">
  <Header />

  <main class="flex-1 w-full max-w-3xl mx-auto px-4 py-12 sm:px-6">
    <h1 class="font-mono text-3xl sm:text-4xl font-bold tracking-tight mb-3">
      <span class="text-[var(--accent)]">&gt;</span> 代码片段
    </h1>
    <p class="text-[var(--text-muted)] mb-8 font-mono text-sm">
      日常积累的代码片段和技术笔记<span class="cursor-blink text-[var(--accent)]">█</span>
    </p>

    <!-- Filter tags -->
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        <a href="/snippets" class="px-2.5 py-1 text-xs font-mono rounded-full border border-[var(--accent)] text-[var(--accent)]">全部</a>
        {allTags.map(tag => (
          <a href={`/snippets?tag=${tag}`} class="px-2.5 py-1 text-xs font-mono rounded-full border border-[var(--border)] text-[var(--text-muted)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors">
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Snippets list -->
    <div class="grid grid-cols-1 gap-4">
      {snippets.map((snippet) => (
        <a
          href={`/snippets/${snippet.id}`}
          class="cyber-card group block"
        >
          <div class="flex items-start justify-between gap-3 mb-2">
            <h3 class="font-mono font-bold group-hover:text-[var(--accent)] transition-colors">{snippet.data.title}</h3>
            {snippet.data.language && (
              <span class="shrink-0 text-xs font-mono px-2 py-0.5 rounded-full border border-[var(--accent-secondary)] text-[var(--accent-secondary)]">
                {snippet.data.language}
              </span>
            )}
          </div>
          <p class="text-sm text-[var(--text-muted)] mb-3">{snippet.data.description}</p>
          {snippet.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {snippet.data.tags.map(tag => (
                <span class="text-xs font-mono text-[var(--text-muted)]">#{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>

    {snippets.length === 0 && (
      <p class="text-[var(--text-muted)] text-center py-12 font-mono text-sm">// 还没有代码片段 ✍️</p>
    )}
  </main>

  <Footer />
</BaseLayout>
