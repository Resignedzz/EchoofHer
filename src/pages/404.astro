---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <div class="font-mono text-8xl font-bold text-accent mb-4">404</div>
    <h1 class="font-mono text-2xl font-bold mb-2">页面未找到</h1>
    <p class="text-[var(--text-muted)] mb-8 font-mono text-sm">
      // 这个页面不存在，或者已经被移动到了其他地方
    </p>
    <a
      href="/"
      class="px-4 py-2 rounded-lg bg-accent text-black font-mono text-sm font-medium hover:bg-accent-hover transition-colors"
    >
      $ cd ~
    </a>
  </div>
</BaseLayout>
