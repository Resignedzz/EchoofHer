---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="resigned's blog" description="A personal blog by resigned">
  <Header />

  <main class="flex-1 w-full max-w-3xl mx-auto px-4 py-12 sm:px-6">
    <!-- Hero -->
    <section class="mb-12">
      <h1 class="font-mono text-4xl sm:text-5xl font-bold tracking-tight mb-3">
        <span class="text-accent">&gt;</span> 你好，我是 <span class="text-accent">resigned</span>
      </h1>
      <p class="text-[var(--text-muted)] text-lg max-w-xl">
        软件智能工程师。写代码、写想法、写生活。<br />
        <span class="font-mono text-sm text-accent/70">cat /dev/random &gt; blog</span>
      </p>
    </section>

    <!-- Post list -->
    <section>
      <h2 class="font-mono text-sm font-bold text-[var(--text-muted)] uppercase tracking-wider mb-6 flex items-center gap-2">
        <span class="text-accent">#</span> 最新文章
      </h2>

      <div class="space-y-1">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 px-3 py-3 rounded-lg hover:bg-[var(--border)] transition-all"
          >
            <time class="text-sm font-mono text-[var(--text-muted)] shrink-0 w-28">
              {formatDate(post.data.date)}
            </time>
            <h3 class="font-medium group-hover:text-accent transition-colors">
              {post.data.title}
            </h3>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="hidden sm:flex items-center gap-2 ml-auto">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="text-xs font-mono text-[var(--text-muted)]">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-[var(--text-muted)] text-center py-12 font-mono text-sm">
          // 还没有文章，开始写第一篇吧 ✍️
        </p>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>
