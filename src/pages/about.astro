const skills = [
  { category: '前端', items: ['JavaScript', 'TypeScript', 'React', 'Vue', 'HTML/CSS', 'Tailwind'], color: '#00ff88' },
  { category: '后端', items: ['Node.js', 'Python', 'Go'], color: '#a855f7' },
  { category: '工具', items: ['Git', 'Docker', 'Linux', 'VS Code'], color: '#3b82f6' },
];
---

<BaseLayout title="关于 - resigned's blog" description="关于我">
  <Header />

  <main class="flex-1 w-full max-w-3xl mx-auto px-4 py-12 sm:px-6">
    <h1 class="font-mono text-3xl sm:text-4xl font-bold tracking-tight mb-8 animate-fade-in">
      <span class="text-[var(--accent)]">&gt;</span> 关于我
    </h1>

    <div class="space-y-8 text-[var(--text)] leading-relaxed">
      <!-- Intro -->
      <section class="cyber-card animate-fade-in animate-delay-1">
        <p class="text-lg mb-4">
          你好，我是 <span class="text-gradient font-semibold">resigned</span>，一名软件智能工程师。
        </p>
        <p class="text-[var(--text-muted)]">
          热衷于编程、数据和设计，喜欢折腾各种有趣的技术。这个博客是我记录思考、分享经验的地方。
        </p>
      </section>

      <!-- Skills -->
      <section class="animate-fade-in animate-delay-2">
        <h2 class="font-mono text-sm font-bold text-[var(--text-muted)] uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class="text-[var(--accent)]">#</span> 技术栈
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {skills.map((group) => (
            <div class="cyber-card group relative overflow-hidden">
              <!-- Top glow line -->
              <div class="absolute top-0 left-0 right-0 h-px opacity-0 group-hover:opacity-100 transition-opacity" style={`background: ${group.color}; box-shadow: 0 0 10px ${group.color};`}></div>

              <!-- Category label -->
              <div class="flex items-center gap-2 mb-4">
                <span class="w-1.5 h-1.5 rounded-full" style={`background: ${group.color}; box-shadow: 0 0 8px ${group.color};`}></span>
                <h3 class="font-mono text-xs font-bold uppercase tracking-widest" style={`color: ${group.color};`}>{group.category}</h3>
              </div>

              <!-- Items with icons -->
              <div class="space-y-2">
                {group.items.map((item) => {
                  const icon = iconMap[item];
                  return (
                    <div class="flex items-center gap-2.5 group/item">
                      {icon && (
                        <div class="w-5 h-5 shrink-0 flex items-center justify-center opacity-40 group-hover/item:opacity-100 transition-opacity duration-300">
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" stroke="none">
                            <path d={icon} />
                          </svg>
                        </div>
                      )}
                      <span class="text-xs font-mono text-[var(--text-muted)] group-hover/item:text-[var(--text)] transition-colors duration-300">{item}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Contact -->
      <section class="animate-fade-in animate-delay-3">
        <h2 class="font-mono text-sm font-bold text-[var(--text-muted)] uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class="text-[var(--accent)]">#</span> 联系方式
        </h2>
        <div class="cyber-card font-mono text-sm space-y-2">
          <div class="flex items-center gap-3">
            <span class="text-[var(--accent)] w-16 shrink-0">github</span>
            <a href="https://github.com/Resignedzz" target="_blank" rel="noopener" class="text-[var(--text)] hover:text-[var(--accent)] transition-colors">Resignedzz</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-[var(--accent)] w-16 shrink-0">email</span>
            <span class="text-[var(--text)]">your@email.com</span>
          </div>
        </div>
      </section>

      <!-- About this blog -->
      <section>
        <h2 class="font-mono text-sm font-bold text-[var(--text-muted)] uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class="text-[var(--accent)]">#</span> 关于本站
        </h2>
        <div class="cyber-card font-mono text-sm text-[var(--text-muted)] space-y-1">
          <div class="flex items-center gap-2">
            <span class="text-[var(--accent)]">$</span> <span class="text-[var(--text)]">cat</span> tech-stack.txt
          </div>
          <p class="pl-5">→ Astro (SSG) + Tailwind CSS + Pagefind + Giscus</p>
          <div class="flex items-center gap-2 pt-2">
            <span class="text-[var(--accent)]">$</span> <span class="text-[var(--text)]">cat</span> hosting.txt
          </div>
          <p class="pl-5">→ TBD</p>
          <div class="flex items-center gap-2 pt-2">
            <span class="text-[var(--accent)]">$</span> <span class="text-[var(--text)]">cat</span> license.txt
          </div>
          <p class="pl-5">→ 内容采用 CC BY-NC-SA 4.0 协议</p>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
