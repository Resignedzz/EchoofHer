---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Giscus from '../components/Giscus.astro';

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    updated?: Date;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;
const { title, description, date, updated, tags = [] } = frontmatter;

const formatDate = (d: Date) => {
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<BaseLayout title={`${title} — resigned's blog`} description={description}>
  <Header />

  <main class="flex-1 w-full max-w-3xl mx-auto px-4 py-12 sm:px-6">
    <article class="prose-custom">
      <!-- Post header -->
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-mono font-bold mb-4 leading-tight">{title}</h1>

        <div class="flex items-center gap-3 text-sm text-[var(--text-muted)]">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          {updated && (
            <>
              <span>·</span>
              <span>更新于 <time datetime={updated.toISOString()}>{formatDate(updated)}</time></span>
            </>
          )}
        </div>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map(tag => (
              <a
                href={`/tags/${tag}`}
                class="px-2.5 py-1 text-xs font-mono rounded-full border border-[var(--border)] text-[var(--text-muted)] hover:border-accent hover:text-accent transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <!-- Post content -->
      <slot />
    </article>

    <!-- Comments -->
    <div class="mt-16 border-t border-[var(--border)] pt-8">
      <h2 class="font-mono text-lg font-bold mb-6 flex items-center gap-2">
        <span class="text-accent">//</span> Comments
      </h2>
      <Giscus />
    </div>
  </main>

  <Footer />
</BaseLayout>
