---

<button
  id="theme-toggle"
  class="p-1.5 rounded-md text-[var(--text-muted)] hover:text-[var(--accent)] transition-all"
  title="切换主题"
  aria-label="切换主题"
>
  <!-- CRT/monitor icon -->
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect width="20" height="14" x="2" y="3" rx="2"/>
    <line x1="8" x2="16" y1="21" y2="21"/>
    <line x1="12" x2="12" y1="17" y2="21"/>
  </svg>
</button>

<script>
  // Toggle CRT scanline effect on/off
  let crtEnabled = true;
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    crtEnabled = !crtEnabled;
    document.body.style.setProperty('--scanline-opacity', crtEnabled ? '1' : '0');
    document.body.classList.toggle('crt-off', !crtEnabled);
  });
</script>
