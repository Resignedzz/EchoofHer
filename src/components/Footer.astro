---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] mt-auto">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-6">
    <div class="font-mono text-xs text-[var(--text-muted)] flex flex-col sm:flex-row items-center justify-between gap-3">
      <div class="flex items-center gap-2 opacity-60">
        <span class="text-[var(--accent)]">$</span>
        <span>echo "Built with Astro" && echo "{year}"</span>
        <span class="cursor-blink text-[var(--accent)]">█</span>
      </div>
      <div class="flex items-center gap-4 opacity-60">
        <a href="/rss.xml" class="hover:text-[var(--accent)] hover:opacity-100 transition-colors">RSS</a>
        <span>·</span>
        <a href="https://github.com/Resignedzz" target="_blank" rel="noopener" class="hover:text-[var(--accent)] hover:opacity-100 transition-colors">GitHub</a>
      </div>
    </div>
  </div>
</footer>
