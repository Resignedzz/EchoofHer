---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] mt-auto">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--text-muted)]">
      <div class="font-mono text-xs">
        <span class="text-accent">$</span> echo "Built with Astro" &amp;&amp; echo "${year}"
      </div>
      <div class="flex items-center gap-4">
        <a href="/rss.xml" class="hover:text-accent transition-colors">RSS</a>
        <a href="https://github.com/Resignedzz" target="_blank" rel="noopener" class="hover:text-accent transition-colors">GitHub</a>
      </div>
    </div>
  </div>
</footer>
